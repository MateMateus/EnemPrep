@model CriarAssuntoViewModel

@{
    ViewData["Title"] = "Editar Assunto";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <a asp-area="Admin" asp-controller="Assuntos" asp-action="Index" asp-route-materiaId="@Model.MateriaId"
            class="text-muted text-decoration-none small d-block mb-3">← @Model.MateriaNome</a>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-4">Editar Assunto</h2>

                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="MateriaId" />
                    <input type="hidden" asp-for="MateriaNome" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Nome" class="form-label fw-semibold"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descricao" class="form-label fw-semibold">Descrição (Opcional)</label>
                        <textarea asp-for="Descricao" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Salvar</button>
                        <a asp-action="Index" asp-route-materiaId="@Model.MateriaId"
                            class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
