@model CriarVideoAulaViewModel

@{
    ViewData["Title"] = "Nova Videoaula";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-4">Nova Videoaula@(string.IsNullOrEmpty(Model.AssuntoNome) ? "" : $" — {Model.AssuntoNome}")</h2>

                <form asp-action="Criar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AssuntoId" />
                    <input type="hidden" asp-for="AssuntoNome" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Titulo" class="form-label fw-semibold"></label>
                        <input asp-for="Titulo" class="form-control" placeholder="Ex: Funções do 2º Grau" />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UrlVideo" class="form-label fw-semibold">URL do Vídeo *</label>
                        <input asp-for="UrlVideo" class="form-control" placeholder="https://youtube.com/..." />
                        <span asp-validation-for="UrlVideo" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DuracaoSegundos" class="form-label fw-semibold">Duração (em segundos) *</label>
                        <input asp-for="DuracaoSegundos" type="number" class="form-control" min="1" max="86400" />
                        <div class="form-text">Ex: 600 = 10 minutos</div>
                        <span asp-validation-for="DuracaoSegundos" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Criar</button>
                        <a asp-action="Index" asp-route-assuntoId="@Model.AssuntoId"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
