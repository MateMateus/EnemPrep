@model EnemPrep.Web.Areas.Admin.ViewModels.Livros.CriarLivroViewModel
@{
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a asp-action="Index" class="text-indigo-600 hover:text-indigo-800">← Voltar</a>
        <h1 class="text-2xl font-bold">Cadastrar Novo Livro</h1>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <form asp-action="Criar" method="post" enctype="multipart/form-data" class="p-6 space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm bg-red-50 p-3 rounded-lg"></div>

            <div>
                <label asp-for="Titulo" class="block text-sm font-medium text-gray-700">Título</label>
                <input asp-for="Titulo" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" />
                <span asp-validation-for="Titulo" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="Descricao" class="block text-sm font-medium text-gray-700">Descrição</label>
                <textarea asp-for="Descricao" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"></textarea>
                <span asp-validation-for="Descricao" class="text-red-600 text-xs"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="MateriaId" class="block text-sm font-medium text-gray-700">Matéria</label>
                    <select asp-for="MateriaId" asp-items="ViewBag.Materias" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
                        <option value="">Selecione uma matéria...</option>
                    </select>
                    <span asp-validation-for="MateriaId" class="text-red-600 text-xs"></span>
                </div>
                <div>
                    <label asp-for="TipoConteudo" class="block text-sm font-medium text-gray-700">Tipo de Conteúdo</label>
                    <select asp-for="TipoConteudo" asp-items="Html.GetEnumSelectList<EnemPrep.Web.Enums.TipoConteudo>()" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
                        <option value="">Selecione o tipo...</option>
                    </select>
                    <span asp-validation-for="TipoConteudo" class="text-red-600 text-xs"></span>
                </div>
            </div>

            <div>
                <label asp-for="CapaArquivo" class="block text-sm font-medium text-gray-700 mb-1">Capa do Material (Imagem)</label>
                <input type="file" asp-for="CapaArquivo" accept="image/*" class="w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
                <span asp-validation-for="CapaArquivo" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div class="pt-4">
                <button type="submit" class="w-full bg-indigo-600 text-white py-2 px-4 rounded-lg hover:bg-indigo-700 transition-colors font-medium">
                    Criar Livro e Continuar
                </button>
            </div>
        </form>
    </div>
</div>
