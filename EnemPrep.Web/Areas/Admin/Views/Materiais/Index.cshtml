@model List<EnemPrep.Web.Areas.Admin.ViewModels.Materiais.MaterialEstudoViewModel>

@{
    ViewData["Title"] = "Materiais de Estudo";
    Guid assuntoId = ViewBag.AssuntoId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">📄 Materiais de Estudo</h1>
    <a asp-action="Criar" asp-route-assuntoId="@assuntoId"
       class="btn btn-primary">+ Novo Material</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum material cadastrado para este assunto.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Título</th>
                    <th>Tipo</th>
                    <th>Link</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="fw-medium">@m.Titulo</td>
                        <td>
                            @{
                                var tipoIcon = m.Tipo switch
                                {
                                    "PDF" => "📕",
                                    "Resumo" => "📝",
                                    "MapaMental" => "🗺",
                                    "LinkExterno" => "🔗",
                                    _ => "📄"
                                };
                            }
                            @tipoIcon @m.Tipo
                        </td>
                        <td>
                            <a href="@m.UrlArquivo" target="_blank" class="btn btn-sm btn-outline-secondary">
                                Abrir
                            </a>
                        </td>
                        <td class="text-end">
                            <form asp-action="Deletar" method="post"
                                  onsubmit="return confirm('Remover material?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@m.Id" />
                                <input type="hidden" name="assuntoId" value="@assuntoId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
