@model CriarMaterialViewModel

@{
    ViewData["Title"] = "Novo Material";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-4">Novo Material — @Model.AssuntoNome</h2>

                <form asp-action="Criar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AssuntoId" />
                    <input type="hidden" asp-for="AssuntoNome" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Titulo" class="form-label fw-semibold"></label>
                        <input asp-for="Titulo" class="form-control" placeholder="Ex: Resumo de Funções" />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Tipo" class="form-label fw-semibold">Tipo *</label>
                        <select asp-for="Tipo" class="form-select">
                            <option value="PDF">📕 PDF</option>
                            <option value="Resumo">📝 Resumo</option>
                            <option value="MapaMental">🗺 Mapa Mental</option>
                            <option value="LinkExterno">🔗 Link Externo</option>
                        </select>
                        <span asp-validation-for="Tipo" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UrlArquivo" class="form-label fw-semibold">URL do Arquivo *</label>
                        <input asp-for="UrlArquivo" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="UrlArquivo" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Criar</button>
                        <a asp-action="Index" asp-route-assuntoId="@Model.AssuntoId"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}
