<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnemPrep (Área do Aluno)</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Tailwind CSS (via CDN temporário para a estrutura inicial, sem quebrar o projeto existente) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Marked.js for Markdown -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <!-- MathJax for LaTeX -->
    <script>
      MathJax = {
        tex: { inlineMath: [['$', '$'], ['\\(', '\\)']], displayMath: [['$$', '$$'], ['\\[', '\\]']] },
        svg: { fontCache: 'global' }
      };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        .htmx-indicator {
            display: none;
        }

        .htmx-request .htmx-indicator {
            display: flex;
        }

        .htmx-request.htmx-indicator {
            display: flex;
        }
    </style>
</head>

<body x-data="{ mobileMenuOpen: false }" class="bg-gray-50 text-gray-800 antialiased font-sans flex h-screen overflow-hidden">

    <!-- Overlay/Backdrop for Mobile Menu -->
    <div x-show="mobileMenuOpen" 
         x-transition.opacity 
         class="fixed inset-0 bg-black/50 z-40 md:hidden" 
         @@click="mobileMenuOpen = false" x-cloak></div>

    <!-- Sidebar -->
    <aside :class="mobileMenuOpen ? 'translate-x-0' : '-translate-x-full'" class="w-64 bg-indigo-700 text-white flex flex-col fixed inset-y-0 left-0 z-50 transform md:relative md:translate-x-0 transition-transform duration-300 ease-in-out">
        <div class="h-16 flex items-center justify-center border-b border-indigo-800 font-bold text-xl tracking-wider">
            EnemPrep
        </div>
        <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
            <a href="/dashboard" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">📊
                Dashboard</a>
            <a href="/cronograma" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">📅
                Cronograma</a>
            <a href="/materias" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">📚 Matérias</a>
            <a href="/livros" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">📖 Livros e Provas</a>
            <a href="/questoes" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">🎯 Questões</a>
            <a href="/questoes/historico" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">⏱️
                Histórico</a>
            <a href="/perfil" class="block px-3 py-2 rounded-md hover:bg-indigo-600 transition-colors">👤 Meu Perfil</a>
            @if (Context.Session.GetString("TipoPerfil") == "Administrador")
            {
                <div class="mt-4 pt-4 border-t border-indigo-500">
                    <a href="/admin/materias" class="block px-3 py-2 rounded-md bg-indigo-800 hover:bg-indigo-900 text-yellow-300 font-bold transition-colors">⚙️ Painel de Admin</a>
                </div>
            }
        </nav>
        <div class="p-4 border-t border-indigo-800">
            <a href="/auth/logout"
                class="block text-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-indigo-700 bg-white hover:bg-indigo-50">Sair</a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col h-screen overflow-hidden">
        <!-- Top Header -->
        <header class="h-16 bg-white shadow flex items-center justify-between px-4 sm:px-6 z-10 shrink-0">
            <div class="flex items-center gap-3">
                <button @@click="mobileMenuOpen = !mobileMenuOpen" type="button" class="md:hidden p-2 -ml-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100 focus:outline-none">
                    <span class="sr-only">Abrir menu principal</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <div class="text-lg sm:text-xl font-semibold text-gray-800 truncate max-w-[200px] sm:max-w-none">@ViewData["Title"]</div>
            </div>
            <div class="flex items-center space-x-4">
                @{
                    var nomeUsuario = Context.Session.GetString("NomeUsuario") ?? "Olá, Visitante";
                }
                <span class="text-sm text-gray-600 font-medium">@nomeUsuario</span>
            </div>
        </header>

        <!-- Main Body -->
        <main class="flex-1 bg-gray-50 @(ViewData["FullWidth"]?.ToString() == "true" ? "p-0 overflow-hidden flex flex-col" : "p-4 sm:p-6 overflow-auto")">
            @if (TempData["Erro"] != null)
            {
                <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-4 flex items-start gap-3">
                    <span class="text-red-500 text-xl">⚠️</span>
                    <div>
                        <p class="text-sm font-medium text-red-800">@TempData["Erro"]</p>
                    </div>
                </div>
            }
            @if (TempData["Sucesso"] != null)
            {
                <div class="mb-4 bg-green-50 border border-green-200 rounded-lg p-4 flex items-start gap-3">
                    <span class="text-green-500 text-xl">✅</span>
                    <div>
                        <p class="text-sm font-medium text-green-800">@TempData["Sucesso"]</p>
                    </div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Global HTMX Indicator -->
    <div id="global-loader" class="htmx-indicator fixed inset-0 bg-gray-900 bg-opacity-50 z-50 items-center justify-center pointer-events-none">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-white"></div>
    </div>
    <script>
        document.body.addEventListener('htmx:configRequest', function() {
            document.body.classList.add('htmx-request');
        });
        document.body.addEventListener('htmx:afterRequest', function() {
            document.body.classList.remove('htmx-request');
        });
    </script>
</body>

</html>
