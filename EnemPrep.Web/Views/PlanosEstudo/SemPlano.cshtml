@{
    ViewData["Title"] = "Cronograma de Estudos";
    Layout = "_LayoutAluno";
}

<div class="max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12">
        <!-- Ícone grande e amigável -->
        <div class="mx-auto w-28 h-28 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
        </div>

        <h2 class="text-2xl font-bold text-gray-800 mb-3">Você ainda não tem um Plano de Estudo</h2>
        <p class="text-gray-500 max-w-md mx-auto mb-10 leading-relaxed">
            Organize sua rotina! Crie seu cronograma selecionando as matérias e assuntos que deseja focar, 
            e nós te ajudaremos a manter a consistência nos seus estudos para o ENEM.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/cronograma/criar" class="inline-flex items-center px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg shadow-sm transition-colors gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
                Criar Meu Primeiro Plano
            </a>
            <a href="/" class="inline-flex items-center px-6 py-3 bg-white hover:bg-gray-50 text-gray-700 font-medium rounded-lg border border-gray-300 shadow-sm transition-colors gap-2">
                ← Voltar ao Início
            </a>
        </div>
    </div>
</div>
