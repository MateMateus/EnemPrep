@model EnemPrep.Web.Models.PlanosEstudo.PlanoEstudoViewModel

@{
    ViewData["Title"] = "Cronograma e Plano de Estudo";
    Layout = "_LayoutAluno";
}

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    
    <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center">
        <div>
            <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">
                Seu Cronograma
            </h1>
            <p class="mt-2 text-gray-600 dark:text-gray-400">
                Organize seus estudos e alcance suas metas para o ENEM.
            </p>
        </div>
        
        <div class="mt-4 md:mt-0">
            <a asp-action="Criar" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Criar Novo Plano
            </a>
        </div>
    </div>

    @if (Model == null)
    {
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 p-12 text-center">
            <div class="mx-auto h-24 w-24 text-gray-300 dark:text-gray-600 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">Nenhum plano ativo encontrado</h3>
            <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto mb-6">
                Você ainda não tem um cronograma de estudos configurado para focar nas matérias do ENEM. Que tal começar um agora?
            </p>
            <a asp-action="Criar" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700">
                Montar meu 1º Plano
            </a>
        </div>
    }
    else
    {
        <!-- Resumo do Plano -->
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 p-6 mb-8 relative overflow-hidden">
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full opacity-10 blur-xl"></div>
            
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Titulo</h2>
                    <div class="mt-2 flex items-center text-sm mb-4 text-gray-500 dark:text-gray-400">
                        <svg class="flex-shrink-0 mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                        </svg>
                        Semana: @Model.DataInicio.ToString("dd/MMM") até @Model.DataFim.ToString("dd/MMM")
                    </div>
                </div>

                <div class="w-full md:w-64">
                    <div class="flex justify-between text-sm font-medium mb-1">
                        <span class="text-gray-700 dark:text-gray-300">Progresso</span>
                        <span class="text-blue-600 dark:text-blue-400">@Model.ProgressoPercentual%</span>
                    </div>
                    <div class="w-full bg-gray-200 dark:bg-slate-700 rounded-full h-2.5">
                        <div class="bg-gradient-to-r from-blue-500 to-indigo-600 h-2.5 rounded-full transition-all duration-500" style="width: @(Model.ProgressoPercentual)%"></div>
                    </div>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 text-right">
                        @Model.ItensConcluidos de @Model.TotalItens itens concluídos
                    </p>
                </div>
            </div>
        </div>

        <!-- Agenda de Itens -->
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Agenda da Semana</h3>
        
        <div class="space-y-4">
            @foreach (var grupo in Model.Itens.GroupBy(i => i.DataPrevista.Date).OrderBy(g => g.Key))
            {
                var ehHoje = grupo.Key == DateTime.Today;
                var perdeuPrazo = grupo.Key < DateTime.Today && grupo.Any(i => i.Status == EnemPrep.Web.Enums.StatusPlanoItem.Pendente);

                <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border @(ehHoje ? "border-blue-500 ring-1 ring-blue-500" : "border-gray-100 dark:border-slate-700") overflow-hidden">
                    <div class="px-6 py-4 bg-gray-50 dark:bg-slate-800/80 border-b border-gray-100 dark:border-slate-700 flex justify-between items-center">
                        <h4 class="text-md font-semibold text-gray-800 dark:text-gray-200 flex items-center">
                            @if (ehHoje)
                            {
                                <span class="bg-blue-100 text-blue-800 text-xs font-semibold mr-2 px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300">Hoje</span>
                            }
                            @grupo.Key.ToString("dddd, dd 'de' MMMM")
                        </h4>

                        @if (perdeuPrazo)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400">
                                Atrasado
                            </span>
                        }
                    </div>
                    
                    <ul class="divide-y divide-gray-100 dark:divide-slate-700">
                        @foreach (var item in grupo)
                        {
                            var concluido = item.Status == EnemPrep.Web.Enums.StatusPlanoItem.Concluido;
                            
                            <li class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-slate-700/50 transition-colors">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center">
                                        @if (concluido)
                                        {
                                            <div class="flex-shrink-0 h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mr-4">
                                                <svg class="h-5 w-5 text-green-600 dark:text-green-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                </svg>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gray-100 dark:bg-slate-700 flex items-center justify-center mr-4">
                                                <span class="h-2.5 w-2.5 rounded-full @(item.EstaAtrasado ? "bg-red-500" : "bg-gray-400")"></span>
                                            </div>
                                        }
                                        
                                        <div>
                                            <a asp-controller="Questoes" asp-action="ListarPorAssunto" asp-route-assuntoId="@item.AssuntoId" class="text-sm font-medium @(concluido ? "text-gray-500 line-through" : "text-gray-900 dark:text-white hover:text-blue-600")">
                                                @item.NomeAssunto
                                            </a>
                                            <p class="text-xs text-gray-500 dark:text-gray-400">
                                                Preparação e Estudo
                                            </p>
                                        </div>
                                    </div>
                                    
                                    <div>
                                        @if (!concluido)
                                        {
                                            <form asp-action="MarcarConcluido" asp-route-itemId="@item.Id" method="post" class="inline">
                                                <button type="submit" class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors">
                                                    Feito ✓
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                             <span class="text-sm font-medium text-green-600 dark:text-green-400">Completado</span>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    }
</div>
