@model IEnumerable<EnemPrep.Web.Models.Gamificacao.ConquistaViewModel>
@{
    ViewData["Title"] = "Minhas Conquistas";
    Layout = "_LayoutAluno";

    var conquistadas = Model.Count(c => c.Desbloqueada);
    var total = Model.Count();
    var percentualProgresso = total > 0 ? (conquistadas * 100) / total : 0;
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">🏅 Minhas Conquistas</h1>
    <p class="text-gray-600">Acompanhe as recompensas e os marcos alcançados ao longo dos seus estudos.</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
    <div class="flex flex-col sm:flex-row justify-between items-center sm:items-start mb-4">
        <div>
            <h3 class="text-lg font-bold text-gray-900">Seu Progresso de Resgate</h3>
            <p class="text-sm text-gray-500">Você já desbloqueou @conquistadas de @total conquistas disponíveis!</p>
        </div>
        <div class="mt-4 sm:mt-0 px-4 py-2 bg-indigo-50 text-indigo-700 rounded-lg font-bold">
            @percentualProgresso% Concluído
        </div>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-3">
        <div class="bg-indigo-600 h-3 rounded-full transition-all duration-1000" style="width: @percentualProgresso%"></div>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    @if (!Model.Any())
    {
        <div class="col-span-full py-12 text-center text-gray-500">
            <span class="text-4xl mb-4 block">🏆</span>
            <p>Nenhuma conquista registrada no sistema ainda.</p>
            <p class="text-sm">Continue estudando, novidades chegarão em breve!</p>
        </div>
    }
    else
    {
        @foreach (var c in Model)
        {
            var isUnlocked = c.Desbloqueada;
            var cardClass = isUnlocked ? "bg-white border-yellow-300 shadow-md ring-1 ring-yellow-400" : "bg-gray-50 border-gray-200 opacity-60 grayscale";
            var iconCircleClass = isUnlocked ? "bg-yellow-100 text-yellow-600" : "bg-gray-200 text-gray-400";
            var textTitleClass = isUnlocked ? "text-gray-900" : "text-gray-500 line-through decoration-gray-300";

            <div class="rounded-xl border p-5 transition-all @cardClass hover:-translate-y-1">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-2xl @iconCircleClass">
                        @(string.IsNullOrEmpty(c.Icone) ? "🏆" : c.Icone)
                    </div>
                    @if (isUnlocked)
                    {
                        <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                            Adquirida
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
                            Bloqueada
                        </span>
                    }
                </div>
                <div>
                    <h4 class="font-bold mb-1 @textTitleClass">@c.Titulo</h4>
                    <p class="text-xs text-gray-500 mb-3 line-clamp-2" title="@c.Descricao">@c.Descricao</p>
                    
                    <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100">
                        <div class="flex items-center text-xs font-bold text-indigo-600">
                            <span class="mr-1">💎</span> +@c.PontosZ XP
                        </div>
                        @if (isUnlocked && c.DataObtencao.HasValue)
                        {
                            <div class="text-[10px] text-gray-400">
                                @c.DataObtencao.Value.ToShortDateString()
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
