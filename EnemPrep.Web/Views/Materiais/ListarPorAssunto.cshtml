@model List<EnemPrep.Web.Models.Shared.MaterialViewModel>
@{
    ViewData["Title"] = "Materiais de Estudo";
    Layout = "_LayoutAluno";
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">📄 Materiais de Apreedizado</h1>
        <p class="text-gray-600 mt-1">Acesse PDFs, Resumos e Mapas Mentais complementares.</p>
    </div>
    <a href="javascript:history.back()" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium">
        &larr; Voltar
    </a>
</div>

@if (!Model.Any())
{
    <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 text-center text-gray-500">
        <div class="text-4xl mb-3">📭</div>
        <p class="text-lg font-medium text-gray-700">Nenhum material encontrado</p>
    </div>
}
else
{
    <ul class="space-y-3">
        @foreach (var mat in Model)
        {
            <li
                class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 hover:bg-gray-50 transition flex items-center justify-between">
                <div class="flex items-center">
                    <div
                        class="h-10 w-10 flex-shrink-0 bg-indigo-100 text-indigo-600 rounded flex items-center justify-center text-lg shadow-sm mr-4">
                        @if (mat.Tipo == "PDF" || mat.Tipo == "Resumo")
                        {
                            <span>📝</span>
                        }
                        else if (mat.Tipo == "MapaMental")
                        {
                            <span>🧠</span>
                        }
                        else
                        {
                            <span>🔗</span>
                        }
                    </div>
                    <div>
                        <h4 class="text-md font-bold text-gray-900">@mat.Titulo</h4>
                        <p class="text-sm text-gray-500 line-clamp-1">@(mat.Descricao ?? $"Material do tipo {mat.Tipo}")</p>
                    </div>
                </div>
                <div>
                    <a href="@mat.UrlArquivo" target="_blank"
                        class="inline-flex items-center px-3 py-1 border border-indigo-600 text-sm font-medium rounded-md text-indigo-600 bg-transparent hover:bg-indigo-50">
                        Acessar
                    </a>
                </div>
            </li>
        }
    </ul>
}
