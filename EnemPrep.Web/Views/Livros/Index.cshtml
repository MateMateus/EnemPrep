@model IEnumerable<EnemPrep.Web.Models.Shared.LivroListViewModel>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Livros e Provas Antigas";
    Layout = "_LayoutAluno";
    var apiBaseUrl = Configuration["ApiBaseUrl"]?.TrimEnd('/');
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">📖 Livros e Provas Antigas</h1>
    <p class="text-gray-600 mt-2">Acesse bibliografias recomendadas e resolva provas de anos anteriores com temas organizados.</p>
</div>

<!-- Filtros -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-8">
    <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="md:col-span-2">
            <label for="busca" class="sr-only">Buscar por título</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                    </svg>
                </div>
                <input type="text" name="busca" id="busca" value="@ViewBag.Busca" class="block w-full pl-10 sm:text-sm border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" placeholder="Buscar material por título...">
            </div>
        </div>
        <div>
            <label for="materiaId" class="sr-only">Matéria</label>
            <select name="materiaId" id="materiaId" asp-items="ViewBag.Materias" class="block w-full sm:text-sm border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" onchange="this.form.submit()">
                <option value="">Todas as Matérias</option>
            </select>
        </div>
        <div>
            <label for="tipo" class="sr-only">Tipo</label>
            <select name="tipo" id="tipo" asp-items="Html.GetEnumSelectList<EnemPrep.Web.Enums.TipoConteudo>()" class="block w-full sm:text-sm border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" onchange="this.form.submit()">
                <option value="">Todos os Tipos</option>
            </select>
            @if (ViewBag.Tipo != null)
            {
                <script>document.getElementById('tipo').value = '@((int)ViewBag.Tipo)';</script>
            }
        </div>
        <!-- Hidden submit on enter for the text input -->
        <button type="submit" class="hidden">Buscar</button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="bg-indigo-50 border-l-4 border-indigo-400 p-6 rounded-lg">
        <div class="flex">
            <div class="flex-shrink-0">
                <span class="text-2xl">📚</span>
            </div>
            <div class="ml-4">
                <p class="text-indigo-800 font-medium text-lg">
                    Sua biblioteca está vazia no momento.
                </p>
                <p class="text-indigo-600 mt-1">
                    Fique atento! Novas provas e livros serão adicionados em breve pela equipe pedagógica.
                </p>
            </div>
        </div>
    </div>
}
else
{
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-6">
        @foreach (var livro in Model)
        {
            <div class="group relative flex flex-col bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 hover:border-indigo-300">
                <!-- Capa do Livro -->
                <div class="aspect-[3/4] overflow-hidden relative">
                    @{
                        string urlCapa = "/img/placeholder-book.png";
                        if (!string.IsNullOrEmpty(livro.UrlCapa)) {
                            urlCapa = livro.UrlCapa.StartsWith("http") ? livro.UrlCapa : $"{apiBaseUrl}{livro.UrlCapa}";
                        }
                    }
                    <img src="@urlCapa" alt="@livro.Titulo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    
                    <!-- Badges Top -->
                    <div class="absolute top-2 left-2 flex flex-col gap-1">
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white/90 text-indigo-800 backdrop-blur-sm shadow-sm border border-indigo-100">
                            @livro.MateriaNome
                        </span>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-black/60 text-white backdrop-blur-sm">
                            @livro.TipoConteudo.ToString()
                        </span>
                    </div>

                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                        <a asp-action="Ler" asp-route-id="@livro.Id" class="w-full bg-white text-indigo-700 py-2 rounded-lg text-center font-bold text-sm">
                            Abrir Livro
                        </a>
                    </div>
                </div>
                
                <!-- Informações -->
                <div class="p-3 sm:p-4 flex-1 flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-gray-800 group-hover:text-indigo-600 transition-colors line-clamp-2" title="@livro.Titulo">@livro.Titulo</h3>
                        <p class="text-xs text-gray-500 mt-1 line-clamp-2">@livro.Descricao</p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-50 flex items-center justify-between text-[10px] font-semibold uppercase tracking-wider text-gray-400">
                        <span>@livro.TotalPaginas Páginas</span>
                        <span class="text-indigo-500">@livro.TotalTemas Temas</span>
                    </div>
                </div>
                
                <a asp-action="Ler" asp-route-id="@livro.Id" class="absolute inset-0 z-0"></a>
            </div>
        }
    </div>
}
