@model EnemPrep.Web.Models.Shared.LivroDetalhesViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = Model.Titulo;
    Layout = "_LayoutAluno";
    var selectedTemaId = ViewData["SelectedTemaId"] as Guid?;
    var apiBaseUrl = Configuration["ApiBaseUrl"]?.TrimEnd('/');
}

<div x-data="readerState()" x-init="init()" class="h-[calc(100vh-10rem)] flex flex-col lg:flex-row overflow-hidden bg-gray-900 rounded-xl shadow-2xl relative">
    
    <!-- Reader Main Content -->
    <div class="flex-1 flex flex-col relative">
        
        <!-- Top Toolbar -->
        <div class="h-12 bg-gray-800 border-b border-gray-700 flex items-center justify-between px-4 text-white z-20">
            <div class="flex items-center gap-2">
                <span class="text-xs bg-indigo-600 px-2 py-0.5 rounded font-bold uppercase tracking-wider">Leituras</span>
                <span class="text-sm font-medium truncate max-w-[200px] md:max-w-md">@Model.Titulo</span>
            </div>
            <div class="flex items-center gap-4">
                <button @@click="toggleSidebar()" class="lg:hidden text-gray-400 hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </div>
        </div>

        <!-- Pages Container -->
        <div class="flex-1 bg-gray-950 relative overflow-hidden select-none" 
             id="reader-scroll-container" 
             @@wheel="zoomWheel($event)"
             @@mousedown="startPan($event)"
             @@touchstart="startPan($event)"
             @@mousemove.window="pan($event)"
             @@touchmove.window="pan($event)"
             @@mouseup.window="stopPan()"
             @@touchend.window="stopPan()">
            
            <template x-for="(page, index) in filteredPages" :key="page.id">
                <div x-show="currentIndex === index" 
                     x-transition:enter="transition ease-out duration-300"
                     x-transition:enter-start="opacity-0"
                     x-transition:enter-end="opacity-100"
                     class="absolute inset-0 flex items-center justify-center p-4">
                    
                    <img :src="page.urlImagem.startsWith('http') ? page.urlImagem : (apiBaseUrl + page.urlImagem)" 
                         :alt="'Página ' + (index + 1)" 
                         draggable="false"
                         class="shadow-2xl rounded-sm object-contain bg-white w-full h-full max-w-full max-h-full"
                         :style="{ transform: 'translate(' + panX + 'px, ' + panY + 'px) scale(' + zoomLevel + ')', transition: isDragging ? 'none' : 'transform 0.1s ease-out', cursor: zoomLevel > 1 ? (isDragging ? 'grabbing' : 'grab') : 'default' }" />
                         
                </div>
            </template>

                @if (!Model.Paginas.Any())
                {
                    <div class="flex items-center justify-center text-gray-500 italic h-full">
                        Este livro ainda não possui páginas cadastradas.
                    </div>
                }
            </div>

        <!-- Controls (Bottom) -->
        <div class="h-16 bg-gray-800 border-t border-gray-700 flex items-center justify-between px-2 sm:px-6 text-white z-20">
            <div class="flex items-center gap-1 sm:gap-4">
                <button @@click="prevPage()" :disabled="currentIndex <= 0" class="p-2 rounded-full hover:bg-gray-700 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <div class="text-[12px] sm:text-sm font-medium whitespace-nowrap">
                    <span x-text="currentPageNumber"></span> / <span x-text="totalFilteredPages"></span>
                </div>
                <button @@click="nextPage()" :disabled="currentIndex >= totalFilteredPages - 1" class="p-2 rounded-full hover:bg-gray-700 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            </div>

            <!-- Zoom Controls -->
            <div class="flex items-center bg-gray-900/50 rounded-lg p-1 border border-gray-700">
                <button @@click="zoomOut()" :disabled="zoomLevel <= 1" class="p-1.5 rounded-md hover:bg-gray-700 text-gray-400 hover:text-white disabled:opacity-20 transition-all">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"></path></svg>
                </button>
                <div class="px-2 text-[10px] sm:text-xs font-bold text-gray-300 w-10 text-center" x-text="Math.round(zoomLevel * 100) + '%'"></div>
                <button @@click="zoomIn()" :disabled="zoomLevel >= 5" class="p-1.5 rounded-md hover:bg-gray-700 text-gray-400 hover:text-white disabled:opacity-20 transition-all">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
                </button>
            </div>

            <div class="hidden md:flex flex-1 mx-8 justify-center">
                <div class="w-full max-w-md bg-gray-700 h-1.5 rounded-full overflow-hidden">
                    <div class="bg-indigo-500 h-full transition-all duration-300" :style="'width: ' + ((currentIndex + 1) / totalFilteredPages * 100) + '%'"></div>
                </div>
            </div>

            <div class="flex items-center">
                <template x-if="currentTemaId">
                    <a :href="'/questoes/resolver?temaId=' + currentTemaId" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 sm:px-5 py-2 rounded-lg font-bold text-[12px] sm:text-sm transition-all flex items-center gap-1 sm:gap-2 shadow-lg shadow-indigo-900/20">
                         <span>📝</span> <span class="hidden xs:inline">Questões</span>
                    </a>
                </template>
            </div>
        </div>
    </div>

    <!-- Sidebar (Right) - Temas e Índice -->
    <aside :class="sidebarOpen ? 'absolute inset-0 z-30 lg:relative' : 'hidden lg:flex'" class="w-full lg:w-72 bg-gray-800 border-l border-gray-700 flex flex-col transition-all duration-300">
        <div class="h-12 bg-gray-900 flex items-center justify-between px-4 border-b border-gray-700 lg:hidden">
            <span class="font-bold text-white text-sm">ÍNDICE DE TEMAS</span>
            <button @@click="toggleSidebar()" class="text-gray-400">✕</button>
        </div>
        
        <div class="p-4 bg-gray-900/50">
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Temas Disponíveis</h3>
            <button @@click="setTema(null)" :class="!currentTemaId ? 'bg-indigo-600 text-white border-indigo-500' : 'text-gray-400 border-gray-700 hover:bg-gray-700/50'" class="w-full text-left px-3 py-2 rounded-lg border text-sm transition-all mb-4">
                📖 Ver Livro Completo
            </button>
        </div>

        <div class="flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar">
            @foreach (var tema in Model.Temas.OrderBy(t => t.PaginaInicial))
            {
                <button 
                    @@click="setTema('@tema.Id', @tema.PaginaInicial, @tema.PaginaFinal)"
                    :class="currentTemaId === '@tema.Id' ? 'bg-indigo-600 text-white ring-2 ring-indigo-400/50' : 'bg-gray-700/30 text-gray-300 hover:bg-gray-700/60 border-transparent'"
                    class="w-full text-left p-3 rounded-xl border transition-all group relative overflow-hidden"
                >
                    <div class="relative z-10">
                        <div class="font-bold text-sm truncate pr-6">@tema.Nome</div>
                        <div class="text-[10px] text-gray-400 mt-1 uppercase font-semibold">Páginas @tema.PaginaInicial - @tema.PaginaFinal</div>
                    </div>
                    <div class="absolute right-3 top-1/2 -translate-y-1/2 text-lg opacity-30 group-hover:opacity-100 transition-opacity">📑</div>
                </button>
            }
            @if (!Model.Temas.Any())
            {
                <p class="text-gray-500 text-xs italic text-center py-8">Nenhum tema mapeado.</p>
            }
        </div>
        
        <div class="p-4 border-t border-gray-700 bg-gray-900/30">
            <div class="text-[10px] text-gray-500 text-center uppercase tracking-widest">EnemPrep Reader v1.0</div>
        </div>
    </aside>

</div>

<style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #4b5563; }
</style>

<script>
    function readerState() {
        const allPages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Paginas.OrderBy(p => p.NumeroProprio), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        const themes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Temas, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        const apiBaseUrl = '@apiBaseUrl';

        return {
            apiBaseUrl: apiBaseUrl,
            allPages: allPages,
            filteredPages: allPages,
            currentIndex: 0,
            currentTemaId: null,
            sidebarOpen: false,
            zoomLevel: 1,
            panX: 0,
            panY: 0,
            isDragging: false,
            startX: 0,
            startY: 0,

            init() {
                // Check if a theme was initially selected
                const initialTemaId = '@(selectedTemaId?.ToString() ?? "")';
                if (initialTemaId) {
                    const theme = themes.find(t => t.Id === initialTemaId);
                    if (theme) {
                        this.setTema(theme.Id, theme.PaginaInicial, theme.PaginaFinal);
                    }
                }
                
                // Keyboard navigation
                window.addEventListener('keydown', (e) => {
                    if (e.key === 'ArrowRight') this.nextPage();
                    if (e.key === 'ArrowLeft') this.prevPage();
                });
            },

            setTema(temaId, startPg = null, endPg = null) {
                this.currentTemaId = temaId;
                
                // Do not filter out pages, keep the array intact
                this.filteredPages = this.allPages;

                if (temaId && startPg !== null) {
                    const targetIndex = this.allPages.findIndex(p => p.numeroProprio === startPg);
                    if (targetIndex !== -1) {
                        this.currentIndex = targetIndex;
                    } else {
                        this.currentIndex = 0;
                    }
                } else {
                    this.currentIndex = 0;
                }
                
                if (window.innerWidth < 1024) this.sidebarOpen = false;
            },

            nextPage() {
                if (this.currentIndex < this.filteredPages.length - 1) {
                    this.currentIndex++;
                    this.resetZoom();
                }
            },

            prevPage() {
                if (this.currentIndex > 0) {
                    this.currentIndex--;
                    this.resetZoom();
                }
            },

            resetZoom() {
                this.zoomLevel = 1;
                this.panX = 0;
                this.panY = 0;
            },

            zoomIn() {
                if (this.zoomLevel < 5) {
                    this.zoomLevel = parseFloat((this.zoomLevel + 0.1).toFixed(2));
                }
            },

            zoomOut() {
                if (this.zoomLevel > 1) {
                    this.zoomLevel = parseFloat((this.zoomLevel - 0.1).toFixed(2));
                    if (this.zoomLevel <= 1) {
                        this.zoomLevel = 1;
                        this.panX = 0;
                        this.panY = 0;
                    }
                }
            },

            zoomWheel(e) {
                if (this.zoomLevel > 1 || e.ctrlKey) {
                    e.preventDefault(); // Impede scroll da página apenas quando ampliado ou aplicando zoom
                }

                if (e.ctrlKey) {
                    // Zoom
                    if (e.deltaY < 0 && this.zoomLevel < 5) {
                        this.zoomLevel = parseFloat((this.zoomLevel + 0.1).toFixed(2));
                    } else if (e.deltaY > 0 && this.zoomLevel > 1) {
                        this.zoomLevel = parseFloat((this.zoomLevel - 0.1).toFixed(2));
                    }
                    if (this.zoomLevel <= 1) {
                        this.zoomLevel = 1;
                        this.panX = 0;
                        this.panY = 0;
                    }
                } else {
                    // Scroll (Pan)
                    if (this.zoomLevel > 1) {
                        this.panY -= e.deltaY;
                        this.panX -= e.deltaX;
                    }
                }
            },

            startPan(e) {
                if (this.zoomLevel > 1) {
                    this.isDragging = true;
                    let clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
                    let clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                    this.startX = clientX - this.panX;
                    this.startY = clientY - this.panY;
                }
            },

            pan(e) {
                if (this.isDragging) {
                    if (e.type.includes('touch')) e.preventDefault();
                    let clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
                    let clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                    this.panX = clientX - this.startX;
                    this.panY = clientY - this.startY;
                }
            },

            stopPan() {
                this.isDragging = false;
            },

            toggleSidebar() {
                this.sidebarOpen = !this.sidebarOpen;
            },

            get currentPageNumber() {
                if (this.filteredPages.length === 0) return 0;
                return this.currentIndex + 1;
            },

            get totalFilteredPages() {
                return this.filteredPages.length;
            }
        }
    }
</script>
