@model EnemPrep.Web.ViewModels.Simulados.SimuladoDetalheViewModel
@{
    ViewData["Title"] = "Instruções do Simulado";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold mb-3">@Model.Titulo</h2>
                    @if (Model.AnoReferencia.HasValue)
                    {
                        <span class="badge bg-dark fs-6 mb-2">Prova Base: ENEM @Model.AnoReferencia</span>
                    }
                </div>

                <div class="alert alert-warning my-4">
                    <h5 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle"></i> Atenção antes de
                        iniciar</h5>
                    <ul class="mb-0 mt-2">
                        <li>Você terá <strong>@(Model.DuracaoMaxima.TotalHours) horas</strong> para concluir.</li>
                        <li>O simulado contém <strong>@Model.Questoes.Count</strong> questões válidas.</li>
                        <li>Reserve um ambiente silencioso e sem interrupções.</li>
                        <li>(MVP) As notas são baseadas em pontuação bruta no momento.</li>
                    </ul>
                </div>

                <form asp-action="Iniciar" method="post" class="text-center">
                    <input type="hidden" name="simuladoId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success btn-lg px-5 py-3 fw-bold rounded-pill shadow">
                        Estou pronto, iniciar o tempo!
                    </button>
                    <div class="mt-3">
                        <a asp-action="Index" class="text-muted text-decoration-none small">Talvez mais tarde,
                            voltar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
