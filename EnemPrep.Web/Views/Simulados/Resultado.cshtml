@model EnemPrep.Web.Models.Simulados.TentativaSimuladoResult
@{
    ViewData["Title"] = "Resultado do Simulado";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0 text-center">
            <div class="card-header bg-success text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-check-circle-fill"></i> Simulado Finalizado</h4>
            </div>
            <div class="card-body p-5">
                <h1 class="display-3 fw-bold text-success mb-2">@Model.NotaTotalBruta</h1>
                <p class="text-muted fs-5 mb-4">Acertos totais (pontuação bruta)</p>

                <ul class="list-group list-group-flush text-start mb-4">
                    <li class="list-group-item px-0"><strong>Início:</strong>
                        @Model.DataInicio.ToLocalTime().ToString("g")</li>
                    <li class="list-group-item px-0"><strong>Término:</strong>
                        @Model.DataFim?.ToLocalTime().ToString("g")</li>
                </ul>

                <a asp-action="Index" class="btn btn-outline-primary btn-lg w-100 rounded-pill">Voltar para
                    Simulados</a>
            </div>
        </div>
    </div>
</div>
