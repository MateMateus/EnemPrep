@model EnemPrep.Web.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login - EnemPrep";
    Layout = "_Layout"; // Usa o layout global (não o layout da area do aluno logado)
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-5">
                <h3 class="text-center mb-4">Acesso EnemPrep</h3>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Email" class="control-label mb-1">E-mail</label>
                        <input asp-for="Email" class="form-control" placeholder="Seu email cadastrado" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Senha" class="control-label mb-1">Senha</label>
                        <input asp-for="Senha" class="form-control" placeholder="Sua senha secreta" />
                        <span asp-validation-for="Senha" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Entrar</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted">Não tem uma conta?</p>
                    <a asp-action="Register" asp-controller="Auth" class="btn btn-outline-secondary">Criar Conta
                        Grátis</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
