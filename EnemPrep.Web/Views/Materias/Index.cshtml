@model List<EnemPrep.Web.Models.Shared.MateriaViewModel>
@{
    ViewData["Title"] = "Matérias";
    Layout = "_LayoutAluno";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">📚 Escolha uma Matéria</h1>
    <p class="text-gray-600 mt-1">Navegue pelas disciplinas para acessar assuntos, videoaulas e materiais.</p>
</div>

@if (!Model.Any())
{
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-yellow-700">
                        Nenhuma matéria cadastrada no momento.
                    </p>
                </div>
            </div>
        </div>
}
else
{
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var materia in Model)
        {
                    <a asp-action="Detalhes" asp-route-id="@materia.Id" class="block bg-white rounded-xl shadow border border-gray-100 p-6 hover:shadow-lg hover:border-indigo-300 transition-all group">
                        <h3 class="text-xl font-bold text-gray-800 group-hover:text-indigo-600 transition-colors">@materia.Nome</h3>
                        <p class="text-gray-500 mt-2 text-sm line-clamp-3">@(materia.Descricao ?? "Sem descrição")</p>
                        <div class="mt-4 text-indigo-600 text-sm font-medium flex items-center">
                            Ver assuntos
                            <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </div>
                    </a>
        }
        </div>
}
