{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=NEON_HOST;Database=NEON_DB;Username=NEON_USER;Password=NEON_PASS;SslMode=Require"
  },
  "Security": {
    "AllowedOrigins": [
      "https://enemprep-web.onrender.com"
    ]
  },
  "Jwt": {
    "Secret": "AZURE_JWT_SECRET_VIA_ENV_VAR",
    "Issuer": "EnemPrep.Api",
    "Audience": "EnemPrep.Web",
    "ExpiryInMinutes": 1440
  },
  "Supabase": {
    "Url": "SUPABASE_URL_VIA_ENV_VAR",
    "ServiceRoleKey": "SUPABASE_KEY_VIA_ENV_VAR",
    "BucketName": "enemprep-uploads"
  }
}
